# --- Shared annotation storage (private HF dataset repo) ---
HF_TOKEN=
ANNOTATIONS_REPO_ID=YOUR_ORG/llm-distractor-annotations

# --- Model serving (OpenAI-compatible endpoint, e.g. LM Studio) ---
# Shared defaults used by BOTH models unless overridden below.
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_API_KEY=lm-studio

# --- Optional per-model overrides ---
# Serve the two target models from different places / under different ids.
# If unset, each falls back to the shared OPENAI_* values above and to the
# default served-model ids in models.py.
# LLAMA_BASE_URL=http://localhost:1234/v1
# LLAMA_API_KEY=lm-studio
# LLAMA_MODEL=meta-llama-3.1-8b-instruct
# GPTOSS_BASE_URL=https://your-hosted-endpoint/v1
# GPTOSS_API_KEY=
# GPTOSS_MODEL=openai/gpt-oss-20b
